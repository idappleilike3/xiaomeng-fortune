LINE_CHANNEL_ID=請貼上_LINE_Channel_ID
LINE_CHANNEL_SECRET=請貼上_LINE_Channel_secret
LINE_CHANNEL_ACCESS_TOKEN=請貼上_LINE_Channel_access_token
# 正式站（Render）— 下列名稱須與 Render Environment 一致；正式值只放 Dashboard
PUBLIC_BASE_URL=https://xiaomeng-fortune.onrender.com
LIFF_ID=請貼上_LIFF_ID
LIFF_URL=https://liff.line.me/請貼上_LIFF_ID
# LINE Developers → LIFF Endpoint（核對用）:
#   https://xiaomeng-fortune.onrender.com/erosee-cosmic-home.html
# LINE Developers → Webhook（核對用）:
#   https://xiaomeng-fortune.onrender.com/api/line/webhook
LINE_OA_URL=https://line.me/R/ti/p/@請貼上_LINE_OA_ID
# 正式站必須為 0；本機無 secret 才可暫設 1
ALLOW_LIFF_STUB=0
HOST=0.0.0.0
PORT=3000

# 綠界 ECPay
ECPAY_MODE=test
ECPAY_MERCHANT_ID=請貼上綠界_MerchantID
ECPAY_HASH_KEY=請貼上綠界_HashKey
ECPAY_HASH_IV=請貼上綠界_HashIV

# OpenAI API
OPENAI_API_KEY=請貼上_sk-..._開頭的_API_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
